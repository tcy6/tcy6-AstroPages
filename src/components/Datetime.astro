---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import IconCalendar from "@/assets/icons/IconCalendar.svg";
import { SITE } from "@/config";
import { useTranslations, type Lang, getLangFromUrl } from "@/i18n/ui";
import { parseShanghaiWallTime } from "@/utils/parseShanghaiWallTime";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = {
  class?: string;
  size?: "sm" | "lg";
  pubDatetime: string | Date;
  timezone?: string;
  modDatetime?: string | Date | null;
  lang?: Lang;
};

const {
  pubDatetime,
  modDatetime,
  size = "sm",
  class: className = "",
  timezone: postTimezone,
  lang = getLangFromUrl(Astro.url),
} = Astro.props;

const t = useTranslations(lang);

/* ========== Formatted Datetime ========== */
const pubDatetimeParsed = parseShanghaiWallTime(pubDatetime, SITE.timezone);
const modDatetimeParsed = modDatetime
  ? parseShanghaiWallTime(modDatetime, SITE.timezone)
  : null;
const isModified =
  !!modDatetimeParsed && modDatetimeParsed.valueOf() > pubDatetimeParsed.valueOf();

const datetime = isModified
  ? modDatetimeParsed!.tz(postTimezone || SITE.timezone)
  : pubDatetimeParsed.tz(postTimezone || SITE.timezone);

// Use different date/time format based on language
const date = lang === "zh" 
  ? datetime.format("YYYY年M月D日 HH:mm") // e.g., '2025年3月22日 09:30'
  : datetime.format("D MMM, YYYY HH:mm"); // e.g., '22 Mar, 2025 09:30'
---

<div class:list={["flex items-center gap-x-2 opacity-80", className]}>
  <IconCalendar
    class:list={[
      "inline-block size-6 min-w-5.5",
      { "scale-90": size === "sm" },
    ]}
  />
  {
    isModified && (
      <span class:list={["text-sm", { "sm:text-base": size === "lg" }]}>
        {t("post.updated")}
      </span>
    )
  }
  <time
    class:list={["text-sm", { "sm:text-base": size === "lg" }]}
    datetime={datetime.toISOString()}>{date}</time
  >
</div>

